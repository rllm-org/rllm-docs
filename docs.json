{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "rLLM",
  "colors": {
    "primary": "#3B82F6",
    "light": "#60A5FA",
    "dark": "#2563EB"
  },
  "favicon": "/favicon.svg",
  "banner": {
    "content": "This site only covers **experimental features**. For the full rLLM documentation, visit [rllm-project.readthedocs.io](https://rllm-project.readthedocs.io/en/latest/).",
    "dismissible": true
  },
  "navigation": {
    "groups": [
      {
        "group": "Getting started",
        "pages": ["index"]
      },
      {
        "group": "Unified workflow trainer",
        "pages": [
          "experimental/unified-trainer",
          "experimental/backend-protocol",
          "experimental/configuration"
        ]
      },
      {
        "group": "Algorithms",
        "pages": [
          "experimental/advantage-estimator",
          "experimental/precompute-advantage"
        ]
      },
      {
        "group": "Monitoring",
        "pages": ["experimental/ui"]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/rllm-org/rllm",
          "icon": "github"
        },
        {
          "anchor": "Blog",
          "href": "https://rllm-project.com/blog.html",
          "icon": "newspaper"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png"
  },
  "navbar": {
    "links": [
      {
        "type": "github",
        "href": "https://github.com/rllm-org/rllm"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Full Docs",
      "href": "https://rllm-project.readthedocs.io/en/latest/"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/rllm-org/rllm"
    }
  }
}
